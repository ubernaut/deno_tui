#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"

if command -v deno >/dev/null 2>&1; then
  exec deno run -A ./scripts/demo_launcher.ts "$@"
fi

if [ -x "$HOME/.deno/bin/deno" ]; then
  exec "$HOME/.deno/bin/deno" run -A ./scripts/demo_launcher.ts "$@"
fi

echo "deno was not found. Install Deno or add $HOME/.deno/bin to PATH." >&2
exit 127
